output$nodes_map <- renderLeaflet({
if (!go_pressed()) {
leaflet() %>%
addTiles() %>%
addPolygons(data=rta_counties, fillColor = "black", fillOpacity = 0.09, color="black", weight=2) %>%
addPolylines(data=routes, color="navy", weight=4, label=~route_long_name) %>%
addCircleMarkers(data=nodes, color = "black", fillColor="lightblue", label=~label, radius=6, weight=1.5, fillOpacity = 0.8)
} else {
map <- leaflet() %>%
addTiles() %>%
addPolygons(data=rta_counties, fillColor = "black", fillOpacity = 0.07, color="black", weight=1.5) %>%
addPolylines(data=routes, color="navy", weight=2, label=~route_long_name, group="Existing Routes") %>%
addPolygons(data=final_bgs_large(), fillColor = "black", fillOpacity = 0.15, color="black", weight=0.5, group="Catchment Block Groups") %>%
addPolygons(data=final_bgs_small(), fillColor = "black", fillOpacity = 0.25, color="black", weight=0.75, group = "Catchment Block Groups") %>%
addCircleMarkers(data=nodes, color = "black", fillColor="white", label=~label, radius=4, weight=1.5, fillOpacity = 0.8, group = "Unselected Nodes")
for (i in 1:(nrow(ib_flow()) - 1)) {
map <- map %>%
addPolylines(
lng     = c(ib_flow()$longitude[i], ib_flow()$longitude[i + 1]),
lat     = c(ib_flow()$latitude[i],  ib_flow()$latitude[i + 1]),
weight  = ib_flow()$weight_scaled[i + 1],  # i+1 because row 1 is NA (start point)
color   = "steelblue",
opacity = 0.8,
group = "Inbound Travel Flows",
label   = paste0(ib_flow()$d_label[i], " → ",
ib_flow()$d_label[i + 1], ": ",
ib_flow()$trips[i + 1], " trips")
)
}
for (i in 1:(nrow(ob_flow()) - 1)) {
map <- map %>%
addPolylines(
lng     = c(ob_flow()$longitude[i], ob_flow()$longitude[i + 1]),
lat     = c(ob_flow()$latitude[i],  ob_flow()$latitude[i + 1]),
weight  = ob_flow()$weight_scaled[i],  # i+1 because row 1 is NA (start point)
color   = "gold",
opacity = 0.8,
group = "Outbound Travel Flows",
label   = paste0(ob_flow()$d_label[i + 1], " → ",
ob_flow()$d_label[i], ": ",
ob_flow()$trips[i], " trips")
)
}
map %>%
addCircleMarkers(
data        = filtered_data(),
label       = ~label,
color       = "black",
fillColor   = "lightblue",
fillOpacity = 0.8,
weight      = 1.5
) %>%
fitBounds(
lng1 = min(ib_flow()$longitude, na.rm = TRUE),
lat1 = min(ib_flow()$latitude,  na.rm = TRUE),
lng2 = max(ib_flow()$longitude, na.rm = TRUE),
lat2 = max(ib_flow()$latitude,  na.rm = TRUE)
) %>%
addLayersControl(overlayGroups = c("Existing Routes", "Unselected Nodes", "Catchment Block Groups", "Inbound Travel Flows", "Outbound Travel Flows"),
options = layersControlOptions(collapsed=T))
}
})
output$table_title <- renderUI({
h4(paste0("Results for: ", "Half-Mile Catchment ", input$day_selection, " and ", input$time_selection))
})
